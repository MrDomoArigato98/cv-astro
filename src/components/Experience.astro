---
import type { ExperienceItem } from "../data/experience";

interface Props {
  items: ExperienceItem[];
}

const { items } = Astro.props;
---

<section class="section" id="experience">
  <div class="section-inner">
    <h2 class="section-title">Experience</h2>

    <div class="timeline">
      {items.map((item, i) => (
        <article class="entry" data-animate style={`--delay: ${i * 80}ms`}>
          <div class="entry-meta">
            <span class="period">{item.period}</span>
            <span class="location">{item.location}</span>
          </div>

          <div class="entry-body">
            <header class="entry-header">
              <h3 class="entry-title">
                {item.title}
                {item.level && <span class="level">{item.level}</span>}
              </h3>
              <p class="company">{item.company}</p>
            </header>

            <ul class="bullets">
              {item.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .entry {
    display: grid;
    /* Meta column is fixed; body takes the rest */
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .entry:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 15%, transparent),
                0 8px 28px -6px color-mix(in srgb, var(--accent) 10%, transparent);
    transform: translateY(-2px);
  }

  /* Stack meta above body on mobile, side-by-side on wider screens */
  @media (min-width: 640px) {
    .entry {
      grid-template-columns: 9rem 1fr;
      gap: 1.5rem;
    }
  }

  .entry-meta {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.25rem 0.75rem;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .entry-meta {
      flex-direction: column;
      gap: 0.25rem;
      padding-top: 0.15rem;
    }
  }

  .period {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--text-dim);
    white-space: nowrap;
  }

  .location {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .entry-title {
    font-size: 1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .level {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--accent-2);
    background: color-mix(in srgb, var(--accent-2) 12%, transparent);
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
  }

  .company {
    font-size: 0.875rem;
    color: var(--accent);
    margin-top: 0.2rem;
    font-weight: 500;
  }

  .bullets {
    margin-top: 0.85rem;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .bullets li {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>
