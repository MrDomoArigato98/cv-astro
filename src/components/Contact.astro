---
import type { Profile } from "../data/profile";

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
---

<section class="section" id="contact">
  <div class="section-inner">
    <h2 class="section-title">Contact</h2>

    <div class="contact-card">
      <p class="cta">
        Interested in working together? Reach out via email or connect on LinkedIn.
      </p>

      <div class="contact-links">
        <a href={`mailto:${profile.email}`} class="contact-btn primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>
          </svg>
          {profile.email}
        </a>

        <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="contact-btn secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Footer lives here since it's tightly coupled to the contact section visually -->
<footer>
  <p>
    &copy; {new Date().getFullYear()} {profile.name}
    &nbsp;·&nbsp;
    <a href={profile.website} target="_blank" rel="noopener noreferrer">{profile.website.replace("https://", "")}</a>
  </p>
</footer>

<style>
  .contact-card {
    padding: clamp(1.25rem, 4vw, 2rem);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cta {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 55ch;
    line-height: 1.7;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Stack buttons full-width on narrow screens */
  @media (max-width: 480px) {
    .contact-links { flex-direction: column; }
    .contact-btn   { width: 100%; justify-content: center; }
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 500;
    /* Prevent long email address from overflowing the button */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: opacity 0.15s, transform 0.15s;
  }

  .contact-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .primary {
    background: var(--accent);
    color: #fff;
  }

  .secondary {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  footer {
    padding: 2rem 1.25rem;
    border-top: 1px solid var(--border);
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  footer a { color: var(--text-dim); }
  footer a:hover { color: var(--text-muted); }
</style>
